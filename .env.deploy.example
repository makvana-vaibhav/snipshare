# Required
MONGO_URI=mongodb+srv://<user>:<pass>@<cluster>/snipshare?retryWrites=true&w=majority
JWT_SECRET=replace_me
JWT_REFRESH_SECRET=replace_me_too
FRONTEND_URL=https://snipshare.yourdomain.com
API_PUBLIC_URL=https://api.snipshare.yourdomain.com

# Optional (only if you use email)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Deployment image tag (latest or commit sha)
IMAGE_TAG=latest
